<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.15.xsd">

    <changeSet id="2-create-business-profiles" author="mehvish">
        <createTable tableName="business_profiles">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true"/>
            </column>
            <column name="business_name" type="VARCHAR(255)"/>
            <column name="description" type="TEXT"/>
            <column name="min_budget" type="INT"/>
            <column name="max_budget" type="INT"/>
            <column name="service_radius_km" type="INT"/>
            <column name="active" type="BOOLEAN" defaultValueBoolean="true"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="business_profiles"
                                 baseColumnNames="id"
                                 referencedTableName="users"
                                 referencedColumnNames="id"
                                 constraintName="fk_business_user"/>
    </changeSet>
</databaseChangeLog>
